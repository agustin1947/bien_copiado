{
  "kind": "collectionType",
  "collectionName": "cuenta_corrientes",
  "info": {
    "singularName": "cuenta-corriente",
    "pluralName": "cuenta-corrientes",
    "displayName": "Cuenta Corriente"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "cliente": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::cliente.cliente"
    },
    "numero_de_orden": {
      "type": "biginteger",
      "required": false
    },
    "fecha_de_ingreso": {
      "type": "date",
      "required": true
    },
    "local": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::local.local"
    },
    "tipo_de_moneda": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::tipo-de-moneda.tipo-de-moneda"
    },
    "Productos": {
      "type": "dynamiczone",
      "components": [
        "cuenta-corriente.cuenta-corriente-items"
      ]
    },
    "total": {
      "type": "decimal"
    },
    "sales_detect_changes_in_items": {  
      "type": "string",
      "customField": "plugin::my-custom-fields.sales-detect-changes-in-items"
    }
  }
}
